{
  "ignorePatterns": [
    { "pattern": "^#" },
    { "pattern": "^mailto:" },
    { "pattern": "/$" },
    { "pattern": "^https://reddit.com" },
    { "pattern": "^https://mitpress.mit.edu" }
  ],
  "replacementPatterns": [
    { "pattern": "^/", "replacement": "{{BASEURL}}/" }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com"],
      "headers": {
        "Accept-Encoding": "gzip, deflate"
      }
    }
  ],
  "timeout": "10s",
  "retryOn429": true,
  "retryCount": 3,
  "aliveStatusCodes": [200, 206, 301, 302, 308, 403]
}
